<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/fake_status_bar"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/fake_wifi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WiFi"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/fake_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100%"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/fake_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="12:00"
            android:textSize="12sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/rental_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Locked • 00:00:00"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_admin"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Admin"
            android:src="@android:drawable/ic_menu_manage"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <Button
            android:id="@+id/btn_show_apps"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="72dp"
            android:layout_marginStart="8dp"
            android:text="Apps" />

        <Button
            android:id="@+id/btn_show_portal"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="96dp"
            android:layout_marginStart="8dp"
            android:text="Insert Coins" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/dashboard_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/dashboard_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select an app. If locked, insert coin first."
                    android:textSize="13sp"
                    android:layout_marginBottom="10dp" />

                <GridLayout
                    android:id="@+id/apps_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3" />

            </LinearLayout>
        </ScrollView>

        <FrameLayout
            android:id="@+id/portal_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <WebView
                android:id="@+id/webview"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

    </FrameLayout>

</LinearLayout>
